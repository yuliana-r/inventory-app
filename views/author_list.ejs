<!DOCTYPE html>
<html lang="en">

<head>
  <%- include('./templates/head'); %>
</head>

<body>
  <!-- header goes here? -->
  <div class="container max-w-full mx-auto sm:px-4">
    <div class="flex flex-wrap">
      <%- include('./templates/sidebar'); %>
      <div class="pl-4 pr-4 sm:w-4/5">
        <h1><%= title %></h1>
        <ul>
          <% if (author_list.length > 0) { %>
          <% author_list.forEach(function(author) { %>
          <li>
            <a href="<%= author.url %>"><%= author.name %></a>
          </li>
          <% }); %>
          <% } else { %>
          <li>There are no authors.</li>
          <% } %>
        </ul>
      </div>
    </div>
  </div>
  <footer>
    <%- include('./templates/footer') %>
  </footer>
  <!-- <script src="/tw-elements/dist/js/tw-elements.umd.min.js" type="text/javascript"></script> -->
</body>

</html>