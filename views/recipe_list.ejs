<!DOCTYPE html>
<html lang="en">

<head>
  <%- include('./templates/head'); %>
</head>

<body>
  <!-- header goes here? -->
  <div class="container max-w-full mx-auto sm:px-4">
    <div class="flex flex-wrap">
      <%- include('./templates/sidebar'); %>
      <div class="pl-4 pr-4 sm:w-4/5">
        <ul>
          <% if (recipe_list.length > 0) { %>
          <% recipe_list.forEach(function(recipe) { %>
          <li>
            <a href="<%= recipe.url %>"><%= recipe.title %></a> (<%= recipe.author.name %>)
            <p> Category:
              <% recipe.category.forEach(function(val, index) { %>
              <a href="<%= val.url %>"><%= val.name %></a><% if (index < recipe.category.length - 1) { %>,<% } %>
              <% }); %>
            </p>
          </li>
          <% }); %>
          <% } else { %>
          <li>There are no recipes.</li>
          <% } %>
        </ul>
      </div>
    </div>
  </div>
  <footer>
    <%- include('./templates/footer') %>
  </footer>
  <!-- <script src="/tw-elements/dist/js/tw-elements.umd.min.js" type="text/javascript"></script> -->
</body>

</html>