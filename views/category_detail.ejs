<!DOCTYPE html>
<html lang="en">

<head>
  <%- include('./templates/head'); %>
</head>

<body>
  <!-- header goes here? -->
  <div class="container max-w-full mx-auto sm:px-4">
    <div class="flex flex-wrap">
      <%- include('./templates/sidebar'); %>
      <div class="pl-4 pr-4 sm:w-4/5">
        <p><%= category.name %></p>
        <p>Recipes:</p>
        <dl>
          <% if (category_recipes.length > 0) { %>
          <% category_recipes.forEach(function(recipe) { %>
          <dt><a href="<%= recipe.url %>"><%= recipe.title %></a></dt>
          <dd><%= recipe.description %></dd>
          <% }); %>
          <% } else { %>
          <p>This category has no recipes.</p>
          <% } %>
        </dl>
      </div>
    </div>
  </div>
  <footer>
    <%- include('./templates/footer') %>
  </footer>
  <!-- <script src="/tw-elements/dist/js/tw-elements.umd.min.js" type="text/javascript"></script> -->
</body>

</html>