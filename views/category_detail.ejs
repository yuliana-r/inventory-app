<!DOCTYPE html>
<html lang="en">

<head>
  <%- include('./templates/head'); %>
</head>

<body>
  <%- include('./templates/header'); %>
  <main>
    <div>
      <p><%= category.name %></p>
      <p>Recipes:</p>
      <dl>
        <% if (category_recipes.length > 0) { %>
        <% category_recipes.forEach(function(recipe) { %>
        <dt><a href="<%= recipe.url %>"><%= recipe.title %></a></dt>
        <dd><%= recipe.description %></dd>
        <% }); %>
        <% } else { %>
        <p>This category has no recipes.</p>
        <% } %>
      </dl>
      <p>
        <a href="<%= category.url %>/delete">Delete category</a>
      </p>
      <p>
        <a href="<%= category.url %>/update">Update category</a>
      </p>
    </div>
  </main>

  <footer>
    <%- include('./templates/footer') %>
  </footer>
</body>

</html>