<!DOCTYPE html>
<html lang="en">

<head>
  <%- include('./templates/head'); %>
</head>

<body>
  <%- include('./templates/header'); %>
  <div>
    <div>
      <div>
        <p><%= title %></p>
        <p><strong>Author:</strong><a href="<%= recipe.author.url %>"><%= recipe.author.name %></a></p>
        <p><strong>Description:</strong> <%= recipe.description %></p>
        <p><strong>Category:</strong>
          <% recipe.category.forEach(function(val, index) { %>
          <a href="<%= val.url %>"><%= val.name %></a><% if (index < recipe.category.length - 1) { %>,<% } %>
          <% }); %>
        </p>
        <a href="<%= recipe.link_to_recipe %>" target="_blank">Click for ingredients and method</a></p>

        <p>
          <a href="<%= recipe.url %>/delete">Delete recipe</a>
        </p>
        <p>
          <a href="<%= recipe.url %>/update">Update recipe</a>
        </p>
      </div>
    </div>
  </div>
  <footer>
    <%- include('./templates/footer') %>
  </footer>
  <!-- <script src="/tw-elements/dist/js/tw-elements.umd.min.js" type="text/javascript"></script> -->
</body>

</html>