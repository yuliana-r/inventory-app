<!DOCTYPE html>
<html lang="en">

<head>
  <%- include('./templates/head'); %>
</head>

<body>
  <!-- header goes here? -->
  <div class="container max-w-full mx-auto sm:px-4">
    <div class="flex flex-wrap">
      <%- include('./templates/sidebar'); %>
      <div class="pl-4 pr-4 sm:w-4/5">
        <h1><%= title %></h1>

        <p>Do you really want to delete this recipe?</p>
        <form method='POST' action=''>
          <div>
            <input id='recipeid' type='hidden' name='recipeid' required='true' value=<%= recipe._id %>>
          </div>
          <button type='submit'>Delete</button>
        </form>
      </div>
    </div>
  </div>
  <footer>
    <%- include('./templates/footer') %>
  </footer>
  <!-- <script src="/tw-elements/dist/js/tw-elements.umd.min.js" type="text/javascript"></script> -->
</body>

</html>