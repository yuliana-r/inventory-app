<!DOCTYPE html>
<html lang="en">

<head>
  <%- include('./templates/head'); %>
</head>

<body>
  <%- include('./templates/header'); %>
  <main>
    <div>
      <h1><%= title %></h1>

      <form action="" method="POST">
        <div>
          <label for="name">Category:</label>
          <input id="name" type="text" placeholder="e.g. Festive" name="name" required value="<%= (typeof category === 'undefined' ? '' : category.name) %>">
        </div>
        <button type="submit">Submit</button>
      </form>

      <% if (locals.errors) { %>
      <ul>
        <% errors.forEach(function(error) { %>
        <li><%= error.msg %></li>
        <% }); %>
      </ul>
      <% } %>
    </div>
  </main>

  <footer>
    <%- include('./templates/footer') %>
  </footer>
</body>

</html>